    {
      "name": "Text Analyze",
      "item": [
        {
          "name": "Analyze Text (MVP)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "var jsonData = pm.response.json();",
                  "pm.test('Has required top-level fields', function () {",
                  "  pm.expect(jsonData).to.have.property('meta');",
                  "  pm.expect(jsonData).to.have.property('linking_chunks');",
                  "  pm.expect(jsonData).to.have.property('syntax');",
                  "});",
                  "pm.test('Has syntax.sentences array', function () {",
                  "  pm.expect(jsonData.syntax).to.have.property('sentences');",
                  "  pm.expect(jsonData.syntax.sentences).to.be.an('array');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"text\": \"I want to go out and take it with us. The beautiful car is in the city.\",\n  \"options\": {\n    \"linking\": { \"mode\": \"mvp\", \"max_chunk_words\": 12 },\n    \"syntax\": { \"mode\": \"mvp\" }\n  }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/text-analyze",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "text-analyze"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Analyze Text - Validation Error",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 400', function () {",
                  "  pm.response.to.have.status(400);",
                  "});",
                  "var jsonData = pm.response.json();",
                  "pm.test('Has validation shape', function () {",
                  "  pm.expect(jsonData).to.have.property('error');",
                  "  pm.expect(jsonData.error.code).to.eql('VALIDATION_ERROR');",
                  "  pm.expect(jsonData.error).to.have.property('fields');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"text\": \"\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/text-analyze",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "text-analyze"
              ]
            }
          },
          "response": []
        }
      ]
